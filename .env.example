NODE_ENV=development
PORT=5006
TICKET_DEFAULT_SLA_HOURS=48
DEFAULT_TICKET_ADMIN_EMAIL=admin@serveaso.com

# Optional: full URL for Prisma (overrides POSTGRES_*)
# Postgres — POSTGRES_DB required (or DATABASE_URL). Loaded from payments/.env.development in monorepo dev.
# DATABASE_URL=postgresql://user:pass@host:5432/your_db

# --- Same as payments service (required on Render if not using monorepo payments/.env) ---
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
# On Render use serveaso1 (not serveaso) — same as other services
POSTGRES_DB=serveaso1

# Skip auto-migrate on startup (default: run migrate deploy)
# PRISMA_SKIP_MIGRATE=true

# Payments base URL for customer in-app notifications (Socket.IO)
# Monorepo local dev (npm run dev): payments on 4100
PAYMENTS_SERVICE_URL=http://127.0.0.1:4100
# INTERNAL_NOTIFY_SECRET=  (defaults to ADMIN_TICKET_SECRET / serveaso-test-push-secret in dev)

# Same secret as utils ADMIN_PUSH_SECRET (must match REACT_APP_ADMIN_TICKET_SECRET on admin web)
# Local dev default if unset: serveaso-test-push-secret (see services/utils/.env.example)
# ADMIN_TICKET_SECRET=
